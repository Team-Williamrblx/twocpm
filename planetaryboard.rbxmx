								<Item class="Script" referent="RBX86E3337F6C654A558BB945268183A69E">
									<Properties>
										<ProtectedString name="Source"><![CDATA[local config = require(script.Parent.Parent.Parent.Parent.Parent.Parent.Parent.Configuration)

while true do
	if config.customization.clock_format == "12h" then
		script.Parent.Text = os.date("%I:%M %p")
	else
		script.Parent.Text = os.date("%H:%M")
	end
	task.wait(5)
end]]></ProtectedString>
