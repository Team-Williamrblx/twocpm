									<Item class="Script" referent="RBX8095FEC15AE6483C8FA1C65E983F1F0A">
										<Properties>
											<ProtectedString name="Source"><![CDATA[local Player = game.Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")

script.Parent.MouseButton1Click:Connect(function()
	local placeId = script.Parent:GetAttribute("placeid")

	-- Debug prints
	print("=== TELEPORT DEBUG ===")
	print("Raw placeId:", placeId)
	print("PlaceId type:", type(placeId))
	print("Current PlaceId:", game.PlaceId)

	if not placeId then
		warn("No placeId attribute found!")
		return
	end

	-- Convert to number if it's a string
	placeId = tonumber(placeId)
	print("Converted placeId:", placeId)

	if not placeId then
		warn("PlaceId is not a valid number!")
		return
	end

	script.Parent.Interactable = false
	script.Parent.Text = "JOINING..."

	-- Add a small delay to ensure the teleport processes
	task.wait(0.1)

	local success, errorMessage = pcall(function()
		TeleportService:Teleport(placeId, Player)
	end)

	if not success then
		warn("Teleport failed: " .. tostring(errorMessage))
		script.Parent.Text = "FAILED"
		task.wait(2)
		script.Parent.Text = "Join!"
		script.Parent.Interactable = true
	end
end)]]></ProtectedString>
