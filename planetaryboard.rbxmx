									<Item class="Script" referent="RBX76A17545A4C947169B27575078C45C44">
										<Properties>
											<ProtectedString name="Source"><![CDATA[local UiStroke = script.Parent.UIStroke
local LiveCircle = script.Parent.LiveCircle
local TweenService = game:GetService("TweenService")

local Tweening = TweenInfo.new(1, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, 0, false, 0)
local TweenCircleIn = TweenService:Create(LiveCircle, Tweening, { BackgroundTransparency = 0.7 })
local TweenStrokeIn = TweenService:Create(UiStroke, Tweening, { Transparency = 0.7 })
local TweenCircleOut = TweenService:Create(LiveCircle, Tweening, { BackgroundTransparency = 0 })
local TweenStrokeOut = TweenService:Create(UiStroke, Tweening, { Transparency = 0 })

while true do
	TweenCircleIn:Play()
	TweenStrokeIn:Play()
	TweenStrokeIn.Completed:Wait()
	TweenCircleOut:Play()
	TweenStrokeOut:Play()
	TweenStrokeOut.Completed:Wait()
end]]></ProtectedString>
