						<Item class="Script" referent="RBX37DC294634E24583918A26233CF78FC4">
							<Properties>
								<ProtectedString name="Source"><![CDATA[local TweenService = game:GetService("TweenService")
script.Parent.Parent.ScrollingFrame:GetPropertyChangedSignal("CanvasPosition"):Connect(function()
	local y = script.Parent.Parent.ScrollingFrame.CanvasPosition.Y
	TweenService:Create(script.Parent.UIStroke, TweenInfo.new(0.05, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), { Thickness = y > 0 and 3 or 0 }):Play()
	TweenService:Create(script.Parent.UICorner, TweenInfo.new(0.05, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), { CornerRadius = y > 0 and UDim.new(0.2, 0) or UDim.new(0, 0) }):Play()
	TweenService:Create(script.Parent, TweenInfo.new(0.05, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), { BackgroundTransparency = y > 0 and 0.35 or 1 }):Play()
	TweenService:Create(script.Parent, TweenInfo.new(0.05, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), { Size = y > 0 and UDim2.new(0.97, 0, 0.15, 0) or UDim2.new(1, 0, 0.15, 0) }):Play()
	TweenService:Create(script.Parent, TweenInfo.new(0.05, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), { Position = y > 0 and UDim2.new(0.5, 0, 0.1, 0) or UDim2.new(0.5, 0, 0.08, 0) }):Play()
end)]]></ProtectedString>
